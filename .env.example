RAN_OUTPUT_MODE=kafka
WEATHER_OUTPUT_MODE=kafka

KAFKA_BOOTSTRAP_SERVERS=broker:29092
RAN_KAFKA_TOPIC=ran_telemetry
WEATHER_KAFKA_TOPIC=weather_events
SPARK_KAFKA_TOPICS=ran_telemetry,weather_events

RAN_INTERVAL_SECONDS=30
RAN_BACKFILL_START=2025-11-23
RAN_BACKFILL_END=
RAN_BACKFILL_STEP_MINUTES=60
RAN_BACKFILL_FILES_PER_DAY=2
RAN_BACKFILL_WINDOWS=00:00-12:00,12:15-00:00
RAN_BACKFILL_UPLOAD=true
RAN_BACKFILL_OVERWRITE=false

WEATHERAPI_KEY=put_your_weatherapi_key_here
WEATHER_LOCATIONS=Alexandria|31.2001,29.9187;Cairo|30.0444,31.2357;Giza|30.0131,31.2089;North Sinai|31.1107,33.7961
# WEATHER_LOCATION=Cairo
WEATHER_POLL_SECONDS=900

POSTGRES_DB=towerhealth
POSTGRES_USER=towerhealth
POSTGRES_PASSWORD=towerhealth

AWS_ACCESS_KEY_ID=put_your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=put_your_aws_secret_key_here
# Fill this only if your AWS credentials are temporary.
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
S3_BUCKET_NAME=towerhealth-bronze
S3_ROTATE_INTERVAL_MS=900000
S3_FLUSH_SIZE=1000

# Optional: use coordinates instead of WEATHER_LOCATION.
# WEATHER_LAT=30.0444
# WEATHER_LON=31.2357
