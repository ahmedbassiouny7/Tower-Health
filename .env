# ── Weather API ─────────────────────────────────────────────────────────────
WEATHERAPI_KEY=3112f685976e4cc5a99115057261805

# ── Kafka (set when broker is running) ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=broker:29092

# ── RAN Generator ───────────────────────────────────────────────────────────
RAN_OUTPUT_MODE=kafka          # stdout | file | kafka
RAN_INTERVAL_SECONDS=30
RAN_KAFKA_TOPIC=ran_telemetry

# ── Weather Producer ─────────────────────────────────────────────────────────
WEATHER_OUTPUT_MODE=kafka      # stdout | kafka
WEATHER_LOCATION=Cairo
WEATHER_POLL_SECONDS=300
WEATHER_KAFKA_TOPIC=weather_events
# WEATHER_LAT=30.0444
# WEATHER_LON=31.2357
